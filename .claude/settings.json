{
  "permissions": {
    "allow": [
      "mcp__notebooklm__ask_question",
      "mcp__notebooklm__remove_notebook",
      "mcp__notebooklm-mcp__notebook_get"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r /:*)",
      "Bash(rm -rf /:*)",
      "Bash(rmdir /s:*)",
      "Bash(del /s /q:*)",
      "Bash(format:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fx:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git branch -D:*)",
      "Bash(DROP DATABASE:*)",
      "Bash(DROP TABLE:*)",
      "Bash(TRUNCATE:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(kill -9:*)",
      "Bash(taskkill /f:*)",
      "Bash(reg delete:*)",
      "Bash(net stop:*)",
      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/bin/*)",
      "Write(/sbin/*)",
      "Write(C:/Windows/*)",
      "Write(C:/Program Files/*)",
      "Edit(/etc/*)",
      "Edit(/usr/*)",
      "Edit(/bin/*)",
      "Edit(/sbin/*)",
      "Edit(C:/Windows/*)",
      "Edit(C:/Program Files/*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"c:/Users/echum/Documents/BPMsoft/.claude/hooks/check-readonly.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"c:/Users/echum/Documents/BPMsoft/.claude/hooks/kestrel-reminder.py\""
          }
        ]
      }
    ]
  }
}
